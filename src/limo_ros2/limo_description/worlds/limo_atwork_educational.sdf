      </link>
    </model>

    <model name="ceiling_visual">
      <static>true</static>
      <pose>0 0 3.05 0 0 0</pose>
      <link name="link">
        <visual name="ceiling"><geometry><box><size>9.0 7.0 0.04</size></box></geometry><material><ambient>0.70 0.69 0.64 1</ambient><diffuse>0.82 0.81 0.76 1</diffuse></material></visual>
        <visual name="light_panel_1"><pose>-2.8 -2.2 -0.025 0 0 0</pose><geometry><box><size>0.55 0.55 0.01</size></box></geometry><material><ambient>1 1 0.92 1</ambient><diffuse>1 1 0.92 1</diffuse><emissive>1 1 0.92 1</emissive></material></visual>
