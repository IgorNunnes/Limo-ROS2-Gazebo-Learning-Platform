        <visual name="light_panel_6"><pose>0.0 0.6 -0.025 0 0 0</pose><geometry><box><size>0.55 0.55 0.01</size></box></geometry><material><ambient>1 1 0.92 1</ambient><diffuse>1 1 0.92 1</diffuse><emissive>1 1 0.92 1</emissive></material></visual>
        <visual name="light_panel_7"><pose>2.0 0.3 -0.025 0 0 0</pose><geometry><box><size>0.55 0.55 0.01</size></box></geometry><material><ambient>1 1 0.92 1</ambient><diffuse>1 1 0.92 1</diffuse><emissive>1 1 0.92 1</emissive></material></visual>
        <visual name="light_panel_8"><pose>-1.6 1.8 -0.025 0 0 0</pose><geometry><box><size>0.55 0.55 0.01</size></box></geometry><material><ambient>1 1 0.92 1</ambient><diffuse>1 1 0.92 1</diffuse><emissive>1 1 0.92 1</emissive></material></visual>
