        <visual name="light_panel_3"><pose>0.8 -1.8 -0.025 0 0 0</pose><geometry><box><size>0.55 0.55 0.01</size></box></geometry><material><ambient>1 1 0.92 1</ambient><diffuse>1 1 0.92 1</diffuse><emissive>1 1 0.92 1</emissive></material></visual>
        <visual name="light_panel_4"><pose>2.6 -1.2 -0.025 0 0 0</pose><geometry><box><size>0.55 0.55 0.01</size></box></geometry><material><ambient>1 1 0.92 1</ambient><diffuse>1 1 0.92 1</diffuse><emissive>1 1 0.92 1</emissive></material></visual>
